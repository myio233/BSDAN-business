EXSCHOOL_HOST=127.0.0.1
EXSCHOOL_PORT=8010
EXSCHOOL_SESSION_SECRET=replace-with-a-random-secret
EXSCHOOL_SESSION_HTTPS_ONLY=false
EXSCHOOL_AUTH_SITE_NAME=localhost

# Optional email verification. Leave blank for local development unless you
# want to exercise registration/login email delivery.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=BSDAN Business Simulator
SMTP_USE_SSL=true
SMTP_USE_TLS=false
