EXSCHOOL_HOST=127.0.0.1
EXSCHOOL_PORT=8010
EXSCHOOL_SESSION_SECRET=replace-with-a-random-secret
EXSCHOOL_AUTH_SITE_NAME=example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=example@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=example@example.com
SMTP_FROM_NAME=example.com
SMTP_USE_SSL=true
SMTP_USE_TLS=false
EMAIL_CODE_EXPIRE_SECONDS=300
EMAIL_CODE_RESEND_SECONDS=90
AUTH_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_RATE_LIMIT_BLOCK_SECONDS=900
AUTH_RATE_LIMIT_IP_ATTEMPTS=20
AUTH_RATE_LIMIT_IDENTITY_ATTEMPTS=8
REGISTER_RATE_LIMIT_IP_ATTEMPTS=6
EMAIL_SEND_RATE_LIMIT_IP_ATTEMPTS=6
EMAIL_SEND_RATE_LIMIT_IDENTITY_ATTEMPTS=3
